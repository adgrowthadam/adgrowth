---
import Layout from '../layouts/Layout.astro';

const WA_NUMERO = '5200000000'; // TODO: reemplazar con el número real
const WA_MENSAJE = encodeURIComponent(
  'Hola, me interesa AdGrowth para mi consultorio. ¿Me pueden dar más información?'
);
const WA_LINK = `https://wa.me/${WA_NUMERO}?text=${WA_MENSAJE}`;

const schemaFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Necesito saber de tecnología o publicidad para usar AdGrowth?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, nosotros nos encargamos de todo. Solo necesitas atender a tus pacientes; el resto lo manejamos nosotros.',
      },
    },
    {
      '@type': 'Question',
      name: '¿En qué ciudades de Tlaxcala y Puebla trabajan?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Trabajamos con consultorios y clínicas en todo el estado de Tlaxcala y Puebla, incluyendo Tlaxcala ciudad, Apizaco, Huamantla, Puebla ciudad, San Andrés Cholula, Atlixco y más.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto tiempo tarda en verse resultados?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Los primeros pacientes interesados llegan desde la primera semana. El sistema se optimiza mes a mes para mejorar los resultados constantemente.',
      },
    },
  ],
};

const servicios = [
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    etiqueta: 'Meta Ads gestionado',
    titulo: 'Pacientes que llegan solos a tu consultorio',
    descripcion:
      'Creamos y manejamos tus anuncios en Facebook e Instagram para que personas en Tlaxcala y Puebla encuentren tu consultorio cuando necesitan atención. Tú no tienes que entender métricas ni campañas — eso es nuestro trabajo.',
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    etiqueta: 'CRM + Automatizaciones',
    titulo: 'Seguimiento automático, sin que se te escape nadie',
    descripcion:
      'Cada persona que muestre interés queda registrada y recibe un seguimiento por WhatsApp de forma automática. Nadie se pierde entre los mensajes, nadie queda sin respuesta. Sin que tú tengas que recordar a nadie ni escribir nada.',
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>`,
    etiqueta: 'Agenda inteligente',
    titulo: 'Tu agenda siempre llena y sin el caos del WhatsApp',
    descripcion:
      'Los pacientes reservan su cita, reciben recordatorios automáticos y confirman su asistencia sin que nadie tenga que perseguirlos. Tú ves todo en un solo lugar, claro y ordenado, sin el desorden de los chats.',
  },
];

const problemas = [
  'Dependes de que alguien te recomiende para que entren nuevos pacientes',
  'Pierdes pacientes interesados entre tantos mensajes de WhatsApp',
  'Pagas publicidad en Meta sin saber si realmente funciona',
  'Cada que quieres crecer, tienes que contratar más personal',
];
---

<Layout
  titulo="AdGrowth | Llena Tu Consultorio Sin Depender de Referidos — Tlaxcala y Puebla"
  descripcion="Llenamos tu agenda de pacientes sin referidos ni WhatsApp desordenado. Sistema completo de atracción, seguimiento y organización para médicos, dentistas y clínicas en Tlaxcala y Puebla."
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- =============================================
       HERO
  ============================================== -->
  <section class="hero" aria-labelledby="hero-titulo">
    <div class="hero__fondo" aria-hidden="true">
      <div class="hero__blob hero__blob--1"></div>
      <div class="hero__blob hero__blob--2"></div>
      <div class="hero__blob hero__blob--3"></div>
      <div class="hero__cuadricula"></div>

      <!-- Floating glass notification cards -->
      <div class="hero__flotante hero__flotante--1">
        <span class="hero__flotante-dot"></span>
        <div class="hero__flotante-texto">
          <p>Nuevo paciente interesado</p>
          <span>Hace 2 min &middot; Puebla</span>
        </div>
      </div>
      <div class="hero__flotante hero__flotante--2">
        <span class="hero__flotante-check">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <div class="hero__flotante-texto">
          <p>Cita confirmada</p>
          <span>Hoy 4:30pm &middot; automático</span>
        </div>
      </div>
    </div>

    <div class="contenedor hero__contenido">
      <div class="hero__insignia" aria-label="Zona de servicio">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Tlaxcala y Puebla
      </div>

      <h1 id="hero-titulo" class="hero__titulo">
        Deja de depender de referidos.<br />
        <span>Llena tu agenda todos los meses.</span>
      </h1>

      <p class="hero__subtitulo">
        AdGrowth es el sistema completo que atrae pacientes con publicidad en Meta, los organiza
        automáticamente y les da seguimiento sin que tú tengas que hacer nada técnico.
        <strong>Para médicos, dentistas y clínicas en Tlaxcala y Puebla.</strong>
      </p>

      <div class="hero__acciones">
        <a href={WA_LINK} class="btn btn--blanco btn--grande" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Quiero más pacientes
        </a>
        <a href="#como-funciona" class="btn btn--contorno-blanco btn--grande">
          Ver cómo funciona
        </a>
      </div>

      <div class="hero__metricas" aria-label="Resultados de nuestros clientes">
        <div class="hero__metrica">
          <strong>+3x</strong>
          <span>más pacientes nuevos al mes</span>
        </div>
        <div class="hero__separador" aria-hidden="true"></div>
        <div class="hero__metrica">
          <strong>0</strong>
          <span>conocimientos técnicos necesarios</span>
        </div>
        <div class="hero__separador" aria-hidden="true"></div>
        <div class="hero__metrica">
          <strong>100%</strong>
          <span>gestionado por nosotros</span>
        </div>
      </div>
    </div>
  </section>

  <!-- =============================================
       PROBLEMAS — ¿Te suena familiar?
  ============================================== -->
  <section class="problemas" aria-labelledby="problemas-titulo">
    <div class="contenedor">
      <p class="seccion__etiqueta">¿Te suena familiar?</p>
      <h2 id="problemas-titulo" class="problemas__titulo">
        El mismo problema que tienen la mayoría de los consultorios en la región
      </h2>
      <ul class="problemas__lista" role="list">
        {
          problemas.map((problema) => (
            <li class="problemas__item">
              <span class="problemas__icono" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
              </span>
              {problema}
            </li>
          ))
        }
      </ul>
      <p class="problemas__resolucion">
        Si reconoces alguno de estos problemas, AdGrowth fue creado exactamente para ti.
      </p>
    </div>
  </section>

  <!-- =============================================
       SERVICIOS / CÓMO FUNCIONA
  ============================================== -->
  <section class="servicios" id="como-funciona" aria-labelledby="servicios-titulo">
    <div class="contenedor">
      <div class="seccion__encabezado">
        <p class="seccion__etiqueta">Cómo funciona AdGrowth</p>
        <h2 id="servicios-titulo" class="seccion__titulo">
          Un sistema completo. Tú solo atiendes pacientes.
        </h2>
        <p class="seccion__subtitulo">
          Nosotros nos encargamos de atraer, organizar y dar seguimiento a cada paciente
          potencial — de principio a fin — sin que necesites saber nada de tecnología ni publicidad.
        </p>
      </div>

      <div class="servicios__grid" id="servicios" role="list">
        {
          servicios.map((servicio, i) => (
            <article class="servicio-card" role="listitem">
              <div class="servicio-card__numero" aria-hidden="true">
                0{i + 1}
              </div>
              <div class="servicio-card__icono" aria-hidden="true" set:html={servicio.icono} />
              <p class="servicio-card__etiqueta">{servicio.etiqueta}</p>
              <h3 class="servicio-card__titulo">{servicio.titulo}</h3>
              <p class="servicio-card__descripcion">{servicio.descripcion}</p>
            </article>
          ))
        }
      </div>

      <div class="servicios__cta">
        <a href={WA_LINK} class="btn btn--primario btn--grande" target="_blank" rel="noopener noreferrer">
          Quiero que AdGrowth trabaje para mi consultorio
        </a>
      </div>
    </div>
  </section>

  <!-- =============================================
       CONTACTO
  ============================================== -->
  <section class="contacto" id="contacto" aria-labelledby="contacto-titulo">
    <div class="contenedor contacto__inner">
      <div class="contacto__texto">
        <p class="seccion__etiqueta seccion__etiqueta--claro">Empieza hoy</p>
        <h2 id="contacto-titulo" class="contacto__titulo">
          ¿Listo para llenar tu agenda sin depender de nadie?
        </h2>
        <p class="contacto__subtitulo">
          Cuéntanos sobre tu consultorio y te mostramos exactamente cómo AdGrowth funciona
          para tu especialidad. Sin compromisos, sin tecnicismos.
        </p>

        <a href={WA_LINK} class="btn btn--whatsapp btn--grande contacto__wa" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Hablar por WhatsApp ahora
        </a>

        <p class="contacto__nota">
          Respondemos en menos de 24 horas · Solo para Tlaxcala y Puebla
        </p>
      </div>

      <div class="contacto__formulario">
        <h3 class="contacto__form-titulo">O déjanos tus datos y te contactamos</h3>
        <!-- TODO: Configura el action con tu proveedor de formularios (Formspree, Netlify Forms, etc.) -->
        <form
          class="formulario"
          action="#"
          method="POST"
          aria-label="Formulario de contacto AdGrowth"
        >
          <div class="formulario__campo">
            <label for="nombre">Nombre completo</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Dr. Martínez López"
              required
              autocomplete="name"
            />
          </div>

          <div class="formulario__campo">
            <label for="especialidad">Especialidad o tipo de consultorio</label>
            <input
              type="text"
              id="especialidad"
              name="especialidad"
              placeholder="Ej: Dentista, Médico general, Clínica..."
              required
            />
          </div>

          <div class="formulario__campo">
            <label for="whatsapp">Tu WhatsApp</label>
            <input
              type="tel"
              id="whatsapp"
              name="whatsapp"
              placeholder="+52 246 000 0000"
              required
              autocomplete="tel"
            />
          </div>

          <div class="formulario__campo">
            <label for="ciudad">Ciudad</label>
            <select id="ciudad" name="ciudad" required>
              <option value="" disabled selected>Selecciona tu ciudad</option>
              <optgroup label="Tlaxcala">
                <option value="tlaxcala-ciudad">Tlaxcala ciudad</option>
                <option value="apizaco">Apizaco</option>
                <option value="huamantla">Huamantla</option>
                <option value="calpulalpan">Calpulalpan</option>
                <option value="otra-tlaxcala">Otra ciudad en Tlaxcala</option>
              </optgroup>
              <optgroup label="Puebla">
                <option value="puebla-ciudad">Puebla ciudad</option>
                <option value="san-andres-cholula">San Andrés Cholula</option>
                <option value="atlixco">Atlixco</option>
                <option value="tehuacan">Tehuacán</option>
                <option value="otra-puebla">Otra ciudad en Puebla</option>
              </optgroup>
            </select>
          </div>

          <button type="submit" class="btn btn--primario btn--grande formulario__submit">
            Quiero más información
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* =============================================
     HERO
  ============================================== */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #060b18 0%, #0b1836 45%, #111f5c 100%);
    color: var(--blanco);
    padding-block: clamp(5rem, 12vw, 9rem);
    text-align: center;
  }

  .hero__fondo {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
  }

  .hero__blob--1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.35), transparent 65%);
    top: -200px;
    left: -150px;
  }

  .hero__blob--2 {
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.25), transparent 65%);
    bottom: -150px;
    right: -100px;
  }

  .hero__blob--3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.2), transparent 65%);
    top: 30%;
    left: 50%;
    transform: translateX(-50%);
    filter: blur(100px);
  }

  .hero__cuadricula {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255 255 255 / 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255 255 255 / 0.025) 1px, transparent 1px);
    background-size: 52px 52px;
  }

  /* Floating glass notification cards */
  .hero__flotante {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 1rem;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 8px 32px rgba(0, 0, 0, 0.35),
      0 2px 8px rgba(0, 0, 0, 0.2);
    color: var(--blanco);
    z-index: 0;
  }

  .hero__flotante--1 {
    top: 22%;
    left: 5%;
    animation: flotar-a 7s ease-in-out infinite;
  }

  .hero__flotante--2 {
    bottom: 22%;
    right: 5%;
    animation: flotar-b 8s ease-in-out infinite;
    animation-delay: -3.5s;
  }

  @keyframes flotar-a {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-14px); }
  }
  @keyframes flotar-b {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(12px); }
  }

  .hero__flotante-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
    flex-shrink: 0;
  }

  .hero__flotante-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.3);
    border: 1px solid rgba(96, 165, 250, 0.4);
    color: #60a5fa;
    flex-shrink: 0;
  }

  .hero__flotante-texto p {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--blanco);
    line-height: 1.2;
  }

  .hero__flotante-texto span {
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 1024px) {
    .hero__flotante {
      display: none;
    }
  }

  /* Hero content */
  .hero__contenido {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    max-width: 820px;
    margin-inline: auto;
  }

  .hero__insignia {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255, 255, 255, 0.09);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radio-full);
    padding: 0.4rem 1rem;
    font-size: var(--texto-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7dd3fc;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .hero__titulo {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .hero__titulo span {
    background: linear-gradient(90deg, #60a5fa, #38bdf8, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitulo {
    font-size: clamp(var(--texto-base), 2vw, var(--texto-lg));
    color: rgba(255, 255, 255, 0.68);
    max-width: 58ch;
    line-height: 1.7;
  }

  .hero__subtitulo strong {
    color: var(--blanco);
    font-weight: 600;
  }

  .hero__acciones {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Glass metrics bar */
  .hero__metricas {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
    padding: 1.5rem 2.5rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radio-xl);
