    <div class="reveal reveal-delay-4 hero-stat-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">
      <div class="stat-badge">
        <div style="font-size:1.5rem; font-weight:900; color:#22c55e;">100%</div>
        <div style="font-size:0.75rem; color:rgba(255,255,255,0.6); margin-top:4px;">Automatizado</div>
      </div>
      <div class="stat-badge">
        <div style="font-size:1.5rem; font-weight:900; color:#22c55e;">24/7</div>
        <div style="font-size:0.75rem; color:rgba(255,255,255,0.6); margin-top:4px;">En operación</div>
