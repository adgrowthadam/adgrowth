    <div class="hero-text-col">
      <div class="reveal">
        <span class="hero-badge" style="display:inline-block; background:rgba(34,197,94,0.12); border:1px solid rgba(34,197,94,0.3); border-radius:100px; padding:6px 20px; font-size:0.78rem; font-weight:600; color:#22c55e; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:24px; white-space:nowrap;">Sistema de Adquisición Inteligente</span>
      </div>

