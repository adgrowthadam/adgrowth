      </div>

    </div>

    <div class="reveal" style="margin-top:44px; text-align:center;">
      <a href="#formulario" class="btn-cta-outline" style="color:#0d1b3e; border-color:#0d1b3e;">
        Quiero salir de esto
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<!-- SOLUCIÓN -->
<section class="geo-navy" style="padding:80px 20px; overflow:hidden;">
  <div style="max-width:1100px; margin:0 auto;">

    <div class="reveal" style="margin-bottom:48px;">
