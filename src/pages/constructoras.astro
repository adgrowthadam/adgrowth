<!-- HERO -->
<section class="geo-navy hero-section" style="padding-block:clamp(5rem,12vw,9rem); padding-top:clamp(7rem,14vw,10rem); min-height:100svh; display:flex; flex-direction:column; justify-content:center; overflow:hidden; text-align:center;">
