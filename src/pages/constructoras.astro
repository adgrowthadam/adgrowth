<!-- CÓMO FUNCIONA -->
<section id="como-funciona" class="geo-white" style="padding:80px 20px;">
  <div style="max-width:700px; margin:0 auto;">

    <div class="reveal" style="margin-bottom:48px;">
      <div class="sep" style="margin-bottom:16px;"></div>
      <span style="font-size:0.8rem; font-weight:600; color:#22c55e; letter-spacing:0.1em; text-transform:uppercase;">El proceso</span>
      <h2 style="font-size:clamp(1.6rem, 5vw, 2.4rem); font-weight:800; color:#0d1b3e; margin-top:12px; line-height:1.2;">
        Así funciona Proyectos en Automático
      </h2>
    </div>

    <div style="display:flex; flex-direction:column; gap:28px;">

      <div class="reveal reveal-delay-1" style="display:flex; gap:20px; align-items:flex-start;">
        <div class="step-num">1</div>
        <div>
          <h3 style="font-weight:700; color:#0d1b3e; font-size:1rem; margin-bottom:6px;">Activamos el sistema de atracción</h3>
