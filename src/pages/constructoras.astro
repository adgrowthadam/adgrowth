    <div class="geo-line-2"></div>
    <div class="hero-orb" style="width:350px; height:350px; background:rgba(34,197,94,0.08); top:-80px; right:-100px;"></div>
    <div class="hero-orb" style="width:250px; height:250px; background:rgba(34,197,94,0.05); bottom:60px; left:-80px;"></div>
  </div>

