      <div class="stat-badge">
        <div style="font-size:1.5rem; font-weight:900; color:#22c55e;">0</div>
        <div style="font-size:0.75rem; color:rgba(255,255,255,0.6); margin-top:4px;">Leads basura</div>
      </div>
    </div>

  </div>
</section>

<!-- PROBLEMA -->
